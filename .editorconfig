# EditorConfig — Consistencia de formato entre editores
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[*.{html,css,js}]
indent_size = 2

[Dockerfile]
indent_size = 4

[Makefile]
indent_style = tab
